# 🚀 SAIMOR Website - Production Configuration
# Copy this file to .env.local and fill in your actual values

# 🌐 Domain Configuration
NEXTAUTH_URL=https://saimor.world
NEXTAUTH_SECRET=your-super-secure-nextauth-secret-here-minimum-32-characters
# ⚠️ WICHTIG: NEXTAUTH_SECRET muss identisch zum Backend sein!

# 🐘 Database (PostgreSQL + Prisma)
DATABASE_URL=postgresql://saimor_user:pass@localhost:5432/saimor_ai
DIRECT_URL=postgresql://saimor_user:pass@localhost:5432/saimor_ai

# 👑 Owner / Roles (Optional)
# - OWNER_PASSWORD enables password login at /owner/login (Credentials Provider)
# - OWNER_EMAILS grants owner role also for email-magic-link logins
OWNER_EMAILS=owner@saimor.world
OWNER_PASSWORD=choose-a-long-random-password
PRO_EMAILS=

# 📧 NextAuth Email Provider (SMTP Configuration)
EMAIL_SERVER_HOST=smtp.your-provider.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@your-domain.com
EMAIL_SERVER_PASSWORD=your-email-password
EMAIL_FROM=noreply@saimor.world

# 🤖 AI Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# 🔗 Backend Integration
BACKEND_BASE_URL=https://api.saimor.world
BACKEND_API_KEY=your-backend-api-key-here
SAIMOR_CORE_BASE_URL=https://api.saimor.world
OS_HOME_URL=https://hq.saimor.world
NEXT_PUBLIC_OS_HOME_URL=https://hq.saimor.world
SSO_SHARED_SECRET=your-shared-secret-with-core-for-world-to-hq-sso
# Optional but recommended for the external Owner Console:
# use a Core API key or system_owner bearer token so /owner can read
# protected instance endpoints like /v3/system/owner/overview.
# A dedicated bridge token can now be rotated via:
# POST /v3/system/owner/rotate-token
OWNER_CONSOLE_CORE_TOKEN=

# 🔗 Webhook Security
N8N_WEBHOOK_URL=https://api.saimor.world/webhook/chat
N8N_WEBHOOK_SECRET=your-webhook-secret-for-n8n-integration

# 🛡️ Security & Anti-Abuse
HCAPTCHA_SECRET=your-hcaptcha-secret-key
HCAPTCHA_SITEKEY=your-hcaptcha-site-key

# 📊 Analytics & Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn-for-error-tracking
REDIS_URL=redis://localhost:6379

# 🚨 Environment
NODE_ENV=production
ENVIRONMENT=production

# 📅 Calendar Integration (for Contact Agent)
CAL_COM_API_KEY=your-cal-com-api-key

# 🤖 Hetzner Agent Integration (Optional)
NEXT_PUBLIC_HETZNER_AGENT_URL=https://your-hetzner-server.com/chat

# Legacy Keys (can be removed)
DOMAIN=api.saimor.world
JWT_SECRET_KEY=your-super-secure-jwt-secret-here-minimum-32-characters
N8N_ENCRYPTION_KEY=your-super-secure-n8n-encryption-key-here-minimum-32-characters
POSTGRES_PASSWORD=your-super-secure-postgres-password-here
OPENAI_API_KEY=sk-your-openai-api-key-here
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=your-email-password
PLAUSIBLE_DOMAIN=api.saimor.world
DEFAULT_TENANT=saimor
BILLING_ENABLED=true
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
