# SAIMOR WORLD - environment template
# Copy to .env.local for local development.
# Put production values into Vercel Project Settings -> Environment Variables.
# Never commit real secrets.

# App / Auth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-with-long-random-secret

# Database
# Local example:
DATABASE_URL=postgresql://saimor_user:pass@localhost:5433/saimor_ai

# Owner console
# /owner/login uses these credentials.
OWNER_EMAILS=owner@example.com
OWNER_PASSWORD=replace-with-long-random-password

# Website -> HQ / Wall token signing
# Use long random values. In production, set both explicitly.
SAIMOR_ENTRY_SECRET=replace-with-long-random-secret
SAIMOR_WALL_SECRET=replace-with-long-random-secret

# Email delivery
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="Saimor <contact@example.com>"

# AI analysis
# Security scan still returns deterministic fallback output if AI is unavailable.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OS / HQ links
OS_HOME_URL=http://localhost:3000
NEXT_PUBLIC_OS_HOME_URL=http://localhost:3000

# WORLD -> Larry Nightwatch customer signal bridge
NIGHTWATCH_SIGNAL_URL=https://dash.saimor.world/api/nightwatch/signals
NIGHTWATCH_SIGNAL_SECRET=replace-with-dashboard-or-nightwatch-signal-secret

# Optional monitoring
SENTRY_DSN=
NEXT_PUBLIC_ENABLE_SPEED_INSIGHTS=false

# Optional rate limits
RATE_LIMIT_SECURITY_SCAN=20
RATE_LIMIT_MAGIC_LINK=8
