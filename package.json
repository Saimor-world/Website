{
  "name": "saimor-live",
  "version": "1.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:auto": "node scripts/dev-auto.js --clean",
    "dev:auto:noclean": "node scripts/dev-auto.js",
    "dev:clean": "npm run kill:3001 && npm run clean:next && next dev -p 3001",
    "build": "next build",
    "build:auto": "node scripts/build-auto.js",
    "build:clean": "npm run clean:next && next build",
    "start": "next start",
    "clean:next": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "kill:3001": "node scripts/kill-port.js 3001",
    "lint": "next lint",
    "test": "vitest run --environment jsdom",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "auth:cleanup:magic": "node scripts/cleanup-magic-tokens.js",
    "preflight:auth": "node scripts/preflight-auth.js",
    "smoke:auth": "node scripts/smoke-auth.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@langchain/anthropic": "^1.3.27",
    "@langchain/core": "^1.1.41",
    "@langchain/google-genai": "^2.1.28",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.46.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vercel/speed-insights": "^1.2.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.3.24",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.13",
    "next-intl": "^3.17.2",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.14",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.44",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vitest": "^4.0.9",
    "zod": "^4.1.7"
  },
  "overrides": {
    "rollup": "^4.60.1",
    "picomatch": "^4.0.4",
    "ajv": "^6.14.0",
    "flatted": "^3.4.2",
    "minimatch@^3.1.2": "^3.1.5",
    "minimatch@^9.0.4": "^9.0.9",
    "brace-expansion@^1.1.7": "^1.1.13",
    "brace-expansion@^2.0.1": "^2.0.3"
  }
}
